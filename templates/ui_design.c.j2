/* Auto-generated implementation for {{ scene_name }} */
#include "{{ base_name }}.h"

{% if icon_bitmaps %}
{{ icon_bitmaps }}
{% endif %}
{% if string_pool %}

/* String pool */
{% for str_literal in string_pool %}
static const char str_{{ loop.index0 }}[] = {{ str_literal }};
{% endfor %}
{% endif %}

/* Widget definitions */
static const UiWidget widgets[] = {
{% for widget in widgets %}
    { // [{{ loop.index0 }}] {{ widget.type }} "{{ widget.text[:20] }}"
        .type = UIW_{{ widget.type.upper() }},
        .x = {{ widget.x }}, .y = {{ widget.y }},
        .width = {{ widget.width }}, .height = {{ widget.height }},
        .border = {{ widget.border }},
        .checked = {{ widget.checked }},
        .value = {{ widget.value }}, .min_value = {{ widget.min_value }}, .max_value = {{ widget.max_value }},
        .text = {{ widget.text_ref }},
        .constraints_json = {{ widget.constraints_ref }},
        .animations_csv = {{ widget.animations_ref }}
    },
{% endfor %}
};

/* Scene definition */
const UiScene {{ base_name }} = {
    .name = "{{ scene_name }}",
    .width = {{ scene_width }},
    .height = {{ scene_height }},
    .widget_count = {{ widget_count }},
    .widgets = widgets
};
