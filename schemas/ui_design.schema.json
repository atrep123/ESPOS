{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/espos/ui_design.schema.json",
  "title": "ESP32OS UI Design",
  "type": "object",
  "required": [
    "scenes"
  ],
  "properties": {
    "width": {
      "type": "integer",
      "minimum": 1
    },
    "height": {
      "type": "integer",
      "minimum": 1
    },
    "groups": {
      "type": "object"
    },
    "scenes": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/scene"
          }
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/scene"
          }
        }
      ]
    }
  },
  "additionalProperties": true,
  "$defs": {
    "scene": {
      "type": "object",
      "required": [
        "widgets"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "bg_color": {
          "$ref": "#/$defs/color"
        },
        "widgets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/widget"
          }
        }
      },
      "additionalProperties": true
    },
    "widget": {
      "type": "object",
      "required": [
        "type",
        "x",
        "y",
        "width",
        "height"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "label",
            "box",
            "button",
            "gauge",
            "progressbar",
            "checkbox",
            "radiobutton",
            "slider",
            "textbox",
            "panel",
            "icon",
            "chart",
            "list",
            "toggle"
          ]
        },
        "x": {
          "type": "integer",
          "minimum": 0
        },
        "y": {
          "type": "integer",
          "minimum": 0
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "z_index": {
          "type": "integer"
        },
        "text": {
          "type": "string"
        },
        "_widget_id": {
          "type": ["string", "null"]
        },
        "id": {
          "type": "string"
        },
        "style": {
          "type": "string"
        },
        "color_fg": {
          "$ref": "#/$defs/color"
        },
        "color_bg": {
          "$ref": "#/$defs/color"
        },
        "border": {
          "type": "boolean"
        },
        "border_style": {
          "type": "string",
          "enum": [
            "none",
            "single",
            "double",
            "rounded",
            "bold",
            "dashed"
          ]
        },
        "align": {
          "type": "string",
          "enum": [
            "left",
            "center",
            "right"
          ]
        },
        "valign": {
          "type": "string",
          "enum": [
            "top",
            "middle",
            "bottom"
          ]
        },
        "text_overflow": {
          "type": "string",
          "enum": [
            "ellipsis",
            "wrap",
            "clip",
            "auto"
          ]
        },
        "max_lines": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "checked": {
          "type": "boolean"
        },
        "value": {
          "type": "integer"
        },
        "min_value": {
          "type": "integer"
        },
        "max_value": {
          "type": "integer"
        },
        "visible": {
          "type": "boolean"
        },
        "enabled": {
          "type": "boolean"
        },
        "constraints_json": {
          "type": "string"
        },
        "runtime": {
          "type": "string",
          "description": "Semicolon-separated key=value pairs for firmware runtime bindings (e.g. 'bind=contrast;kind=int;min=0;max=255'). Empty string means no binding.",
          "pattern": "^$|^[A-Za-z_][A-Za-z0-9_.]*=.*(;[A-Za-z_][A-Za-z0-9_.]*=.*)*$"
        },
        "animations_csv": {
          "type": "string"
        },
        "animations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "data_points": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "list_items": {
          "type": "array",
          "description": "List widget entries (alternative to newline-separated text). Maps to WidgetConfig.items.",
          "items": {
            "type": "string"
          }
        },
        "icon_char": {
          "type": "string",
          "description": "Icon character for icon widgets."
        },
        "padding_x": {
          "type": "integer",
          "minimum": 0,
          "description": "Horizontal padding inside widget (default 1)."
        },
        "padding_y": {
          "type": "integer",
          "minimum": 0,
          "description": "Vertical padding inside widget (default 0)."
        },
        "margin_x": {
          "type": "integer",
          "minimum": 0,
          "description": "Horizontal margin outside widget (default 0)."
        },
        "margin_y": {
          "type": "integer",
          "minimum": 0,
          "description": "Vertical margin outside widget (default 0)."
        },
        "locked": {
          "type": "boolean",
          "description": "Prevent editing this widget in the designer."
        },
        "theme_fg_role": {
          "type": "string",
          "description": "Theme role binding for foreground color."
        },
        "theme_bg_role": {
          "type": "string",
          "description": "Theme role binding for background color."
        },
        "state": {
          "type": "string",
          "description": "Current state variant (default, pressed, disabled, etc.)."
        },
        "state_overrides": {
          "type": "object",
          "description": "Per-state property overrides. Keys are state names, values are property dicts.",
          "additionalProperties": {
            "type": "object"
          }
        },
        "font_size": {
          "type": ["integer", "null"],
          "minimum": 1,
          "description": "Font size override (null = use default)."
        },
        "bold": {
          "type": "boolean",
          "description": "Use bold font rendering."
        },
        "corner_radius": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Corner radius for rounded widgets (null = sharp corners)."
        },
        "border_width": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Border width override (null = default)."
        },
        "border_color": {
          "description": "Border color override.",
          "oneOf": [
            {"$ref": "#/$defs/color"},
            {"type": "null"}
          ]
        },
        "bg_color": {
          "description": "Background color (legacy alias for color_bg).",
          "oneOf": [
            {"$ref": "#/$defs/color"},
            {"type": "null"}
          ]
        },
        "color": {
          "description": "Foreground color (legacy alias for color_fg).",
          "oneOf": [
            {"$ref": "#/$defs/color"},
            {"type": "null"}
          ]
        },
        "text_color": {
          "description": "Text color (legacy alias for color_fg).",
          "oneOf": [
            {"$ref": "#/$defs/color"},
            {"type": "null"}
          ]
        },
        "constraints": {
          "type": "object",
          "description": "Layout constraints metadata."
        },
        "responsive_rules": {
          "type": "array",
          "description": "Responsive layout rules.",
          "items": {
            "type": "object"
          }
        }
      },
      "additionalProperties": false
    },
    "color": {
      "type": "string",
      "description": "Named color (black/white/...) or #RRGGBB",
      "anyOf": [
        {
          "pattern": "^#[0-9a-fA-F]{6}$"
        },
        {
          "minLength": 1
        }
      ]
    }
  }
}

