{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/espos/ui_design.schema.json",
  "title": "ESP32OS UI Design",
  "type": "object",
  "required": [
    "scenes"
  ],
  "properties": {
    "width": {
      "type": "integer",
      "minimum": 1
    },
    "height": {
      "type": "integer",
      "minimum": 1
    },
    "groups": {
      "type": "object"
    },
    "scenes": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/scene"
          }
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/scene"
          }
        }
      ]
    }
  },
  "additionalProperties": true,
  "$defs": {
    "scene": {
      "type": "object",
      "required": [
        "widgets"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "bg_color": {
          "$ref": "#/$defs/color"
        },
        "widgets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/widget"
          }
        },
        "rules": {
          "type": "array",
          "description": "Visual-backend behavior rules for this scene: trigger -> optional conditions -> action(s). Compiled to deterministic C in ui_design.c and executed by the firmware logic service.",
          "items": {
            "$ref": "#/$defs/rule"
          }
        }
      },
      "additionalProperties": true
    },
    "widget": {
      "type": "object",
      "required": [
        "type",
        "x",
        "y",
        "width",
        "height"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "label",
            "box",
            "button",
            "gauge",
            "progressbar",
            "checkbox",
            "radiobutton",
            "slider",
            "textbox",
            "panel",
            "icon",
            "chart",
            "list",
            "toggle"
          ]
        },
        "x": {
          "type": "integer",
          "minimum": 0
        },
        "y": {
          "type": "integer",
          "minimum": 0
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "z_index": {
          "type": "integer"
        },
        "text": {
          "type": "string"
        },
        "_widget_id": {
          "type": ["string", "null"]
        },
        "id": {
          "type": "string"
        },
        "style": {
          "type": "string",
          "description": "Widget style. Simple tokens (default, bold, inverse, highlight) or space-separated combos (e.g. 'bold highlight'). Charts may use 'bar' or 'line'."
        },
        "color_fg": {
          "$ref": "#/$defs/color"
        },
        "color_bg": {
          "$ref": "#/$defs/color"
        },
        "border": {
          "type": "boolean"
        },
        "border_style": {
          "type": "string",
          "enum": [
            "none",
            "single",
            "double",
            "rounded",
            "bold",
            "dashed"
          ]
        },
        "align": {
          "type": "string",
          "enum": [
            "left",
            "center",
            "right"
          ]
        },
        "valign": {
          "type": "string",
          "enum": [
            "top",
            "middle",
            "bottom"
          ]
        },
        "text_overflow": {
          "type": "string",
          "enum": [
            "ellipsis",
            "wrap",
            "clip",
            "auto"
          ]
        },
        "max_lines": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "checked": {
          "type": "boolean"
        },
        "value": {
          "type": "integer"
        },
        "min_value": {
          "type": "integer"
        },
        "max_value": {
          "type": "integer"
        },
        "visible": {
          "type": "boolean"
        },
        "enabled": {
          "type": "boolean"
        },
        "constraints_json": {
          "type": "string"
        },
        "runtime": {
          "type": "string",
          "description": "Semicolon-separated key=value pairs for firmware runtime bindings (e.g. 'bind=contrast;kind=int;min=0;max=255'). Empty string means no binding.",
          "pattern": "^$|^[A-Za-z_][A-Za-z0-9_.]*=.*(;[A-Za-z_][A-Za-z0-9_.]*=.*)*$"
        },
        "animations_csv": {
          "type": "string"
        },
        "animations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "data_points": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "items": {
          "type": "array",
          "description": "List widget entries. This is the canonical key emitted by WidgetConfig save (asdict). Always present on every widget (default []).",
          "items": {
            "type": "string"
          }
        },
        "list_items": {
          "type": "array",
          "description": "Legacy/external read-side alias for `items` (alternative to newline-separated text). Normalized into WidgetConfig.items on load; never emitted by save.",
          "items": {
            "type": "string"
          }
        },
        "icon_char": {
          "type": "string",
          "description": "Icon character for icon widgets."
        },
        "padding_x": {
          "type": "integer",
          "minimum": 0,
          "description": "Horizontal padding inside widget (default 1)."
        },
        "padding_y": {
          "type": "integer",
          "minimum": 0,
          "description": "Vertical padding inside widget (default 0)."
        },
        "margin_x": {
          "type": "integer",
          "minimum": 0,
          "description": "Horizontal margin outside widget (default 0)."
        },
        "margin_y": {
          "type": "integer",
          "minimum": 0,
          "description": "Vertical margin outside widget (default 0)."
        },
        "locked": {
          "type": "boolean",
          "description": "Prevent editing this widget in the designer."
        },
        "theme_fg_role": {
          "type": "string",
          "description": "Theme role binding for foreground color."
        },
        "theme_bg_role": {
          "type": "string",
          "description": "Theme role binding for background color."
        },
        "state": {
          "type": "string",
          "description": "Current state variant (default, pressed, disabled, etc.)."
        },
        "state_overrides": {
          "type": "object",
          "description": "Per-state property overrides. Keys are state names, values are property dicts.",
          "additionalProperties": {
            "type": "object"
          }
        },
        "font_size": {
          "type": ["integer", "null"],
          "minimum": 1,
          "description": "Font size override (null = use default)."
        },
        "bold": {
          "type": "boolean",
          "description": "Use bold font rendering."
        },
        "corner_radius": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Corner radius for rounded widgets (null = sharp corners)."
        },
        "border_width": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Border width override (null = default)."
        },
        "border_color": {
          "description": "Border color override.",
          "oneOf": [
            {"$ref": "#/$defs/color"},
            {"type": "null"}
          ]
        },
        "bg_color": {
          "description": "Background color (legacy alias for color_bg).",
          "oneOf": [
            {"$ref": "#/$defs/color"},
            {"type": "null"}
          ]
        },
        "color": {
          "description": "Foreground color (legacy alias for color_fg).",
          "oneOf": [
            {"$ref": "#/$defs/color"},
            {"type": "null"}
          ]
        },
        "text_color": {
          "description": "Text color (legacy alias for color_fg).",
          "oneOf": [
            {"$ref": "#/$defs/color"},
            {"type": "null"}
          ]
        },
        "constraints": {
          "type": "object",
          "description": "Layout constraints metadata."
        },
        "responsive_rules": {
          "type": "array",
          "description": "Responsive layout rules.",
          "items": {
            "type": "object"
          }
        },
        "events": {
          "type": "object",
          "description": "Visual-backend event handlers for this widget. Each handler key maps to a list of actions run when the event fires on the firmware. The widget must have an 'id'/'_widget_id' for its events to be wired.",
          "properties": {
            "on_press": {
              "type": "array",
              "description": "Actions run when this widget is activated (A button / encoder press / toggle).",
              "items": {"$ref": "#/$defs/action"}
            },
            "on_change": {
              "type": "array",
              "description": "Actions run when this widget's value/checked state changes (slider/checkbox/toggle/list).",
              "items": {"$ref": "#/$defs/action"}
            },
            "on_focus": {
              "type": "array",
              "description": "Actions run when this widget receives focus.",
              "items": {"$ref": "#/$defs/action"}
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "color": {
      "type": "string",
      "description": "Named color (black/white/...) or #RRGGBB",
      "anyOf": [
        {
          "pattern": "^#[0-9a-fA-F]{6}$"
        },
        {
          "minLength": 1
        }
      ]
    },
    "rule": {
      "type": "object",
      "description": "A scene rule: when 'trigger' fires and all 'conditions' hold, run 'actions' in order.",
      "required": ["trigger", "actions"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Optional human label (for the designer / generated C comment)."
        },
        "trigger": {"$ref": "#/$defs/trigger"},
        "conditions": {
          "type": "array",
          "description": "Optional AND/OR list of boolean conditions; all must hold (subject to op) for actions to run.",
          "items": {"$ref": "#/$defs/condition"}
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/action"}
        }
      },
      "additionalProperties": false
    },
    "trigger": {
      "type": "object",
      "description": "What starts a rule.",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["boot", "timer", "gpio_in", "ble_recv", "lora_recv", "widget"]
        },
        "timer_id": {
          "type": "integer",
          "minimum": 0,
          "maximum": 15,
          "description": "timer: which logic timer slot (0..15) firing this rule."
        },
        "pin": {
          "type": "integer",
          "minimum": 0,
          "maximum": 48,
          "description": "gpio_in: GPIO number whose level change fires this rule."
        },
        "edge": {
          "type": "string",
          "enum": ["rising", "falling", "any"],
          "description": "gpio_in: which edge fires (default 'any')."
        },
        "widget": {
          "type": "string",
          "description": "widget: id of the widget whose event fires this rule."
        },
        "event": {
          "type": "string",
          "enum": ["on_press", "on_change", "on_focus"],
          "description": "widget: which widget event fires this rule."
        }
      },
      "additionalProperties": false
    },
    "action": {
      "type": "object",
      "description": "One real, codegen-backed effect. Every type compiles to working firmware C.",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "set_scene",
            "set_widget",
            "set_var",
            "gpio_write",
            "toast",
            "start_timer",
            "stop_timer",
            "ble_send",
            "lora_send"
          ]
        },
        "scene": {"type": "string", "description": "set_scene: target scene name."},
        "widget": {"type": "string", "description": "set_widget: target widget id."},
        "prop": {
          "type": "string",
          "enum": ["value", "text", "checked", "visible", "enabled"],
          "description": "set_widget: which widget property to set."
        },
        "value": {
          "type": ["integer", "string", "boolean"],
          "description": "set_widget value, gpio level (0/1), timer ms, or var int expression depending on action."
        },
        "text": {"type": "string", "description": "set_widget(text=...) / toast message."},
        "var": {"type": "string", "description": "set_var: integer variable name (a-z0-9_)."},
        "expr": {
          "type": "string",
          "description": "set_var: bounded integer expression over int vars / literals (e.g. 'counter + 1')."
        },
        "pin": {"type": "integer", "minimum": 0, "maximum": 48, "description": "gpio_write pin."},
        "level": {"type": "integer", "minimum": 0, "maximum": 1, "description": "gpio_write level."},
        "timer_id": {
          "type": "integer",
          "minimum": 0,
          "maximum": 15,
          "description": "start_timer/stop_timer slot."
        },
        "ms": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3600000,
          "description": "start_timer period in milliseconds."
        },
        "bytes": {
          "type": "string",
          "description": "ble_send/lora_send: payload as a short ASCII/hex string (board must expose the radio peripheral)."
        }
      },
      "additionalProperties": false
    },
    "condition": {
      "type": "object",
      "description": "A boolean test on an int var or a widget value/checked state.",
      "required": ["lhs", "op", "rhs"],
      "properties": {
        "lhs": {
          "type": "string",
          "description": "Left side: 'var:<name>' (int var), 'widget:<id>.value', or 'widget:<id>.checked'."
        },
        "op": {
          "type": "string",
          "enum": ["==", "!=", "<", ">", "<=", ">="]
        },
        "rhs": {
          "type": ["integer", "string"],
          "description": "Right side: an integer literal, 'var:<name>', or a widget ref like lhs."
        },
        "join": {
          "type": "string",
          "enum": ["&&", "||"],
          "description": "How this condition combines with the NEXT one in the list (default '&&')."
        }
      },
      "additionalProperties": false
    }
  }
}

