{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Designer: Launch (Empty 128x64)",
      "type": "shell",
      "command": "python",
      "args": [
        "tools/launch_designer.py",
        "--width", "128",
        "--height", "64"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "Designer: Launch (320x240)",
      "type": "shell",
      "command": "python",
      "args": [
        "tools/launch_designer.py",
        "--width", "320",
        "--height", "240"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "Designer: Open JSON (prompt)",
      "type": "shell",
      "command": "python",
      "args": [
        "tools/launch_designer.py",
        "--json",
        "${input:jsonPath}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "jsonPath",
      "type": "promptString",
      "description": "Path to a design JSON (relative to workspace)",
      "default": "test_scene.json"
    }
  ]
}
{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Simulator: simctl icon_demo (auto)",
      "type": "shell",
      "command": "powershell -NoProfile -Command \"$p=Get-Content .\\sim_ports.json | ConvertFrom-Json; if (-not $p.rpc_port) { Write-Host 'rpc_port not found in sim_ports.json'; exit 1 }; python .\\simctl.py $($p.rpc_port) icon_demo\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
